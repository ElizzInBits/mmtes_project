CONTROLE FINANCEIRO (Autônomos) class Lancamento {
    private String descricao;
    private double valor;
    private boolean isReceita; // true para receita, false para despesa

    public Lancamento(String descricao, double valor, boolean isReceita) {
        this.descricao = descricao;
        this.valor = valor;
        this.isReceita = isReceita;
    }

    public double getValorReal() {
        return isReceita ? valor : -valor;
    }

    @Override
    public String toString() {
        return String.format("%s %s: R$ %.2f", isReceita ? "[+] RECEITA" : "[-] DESPESA", descricao, valor);
    }
}
class FinancasAutonomo {
    private List<Lancamento> extrato = new ArrayList<>();

    public void registrar(String desc, double val, boolean isReceita) {
        extrato.add(new Lancamento(desc, val, isReceita));
    }

    public void exibirBalanco() {
        double saldo = 0;
        System.out.println("\n--- FLUXO DE CAIXA ---");
        for (Lancamento l : extrato) {
            System.out.println(l);
            saldo += l.getValorReal();
        }
        System.out.printf("SALDO LÍQUIDO DISPONÍVEL: R$ %.2f\n---------------------\n", saldo);
    }
}
