}
 PROGAMA PRINCIPAL// 
 public class Main {
    public static void main(String[] args) {
        // Inicializa o controle financeiro do autônomo
        FinancasAutonomo financeiro = new FinancasAutonomo();

        // 1. Executa o módulo de Cozinha
        PedidoCozinha pedido1 = new PedidoCozinha("Risoto de Camarão", 2);
        pedido1.enviar();

        // 2. Executa o módulo de Requisição de Jóias
        RequisicaoJoia joia1 = new RequisicaoJoia("Anel Solitário", "Ouro Branco", 2500.00);
        joia1.processar(financeiro);

        // 3. Executa o módulo Financeiro direto (Ex: pagamento de custos fixos)
        financeiro.registrar("Insumos de Ourivesaria", 600.00, false);
        financeiro.registrar("Internet/Telefone", 120.00, false);

        // Exibe o resultado financeiro consolidado
        financeiro.exibirBalanco();
    }
}

